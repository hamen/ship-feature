#!/usr/bin/env bash
# ship-feature — a small helper for the ship-feature workflow (see WORKFLOW.md).
#
# v1 commands:
#   ship-feature preflight   Assert the working copy is set up for step 4 (worktree, feature
#                            branch off origin/HEAD, excluded marker, ancestry). Non-zero on failure.
#   ship-feature relay [..]  Transparent pass-through to `pr-review-relay`: forwards all args, preserves
#                            stdout and the EXACT exit code, and prints (on stderr) a one-line reminder of
#                            what each code means for the workflow.
#   ship-feature help        This message.
#
# The workflow itself lives in WORKFLOW.md; this tool does not drive it. State/resume is intentionally
# NOT in v1. Bash 3.2-safe (no associative arrays, no ${x^}); no jq dependency.
set -uo pipefail

die()  { echo "✖ $*" >&2; exit 1; }
warn() { echo "  ! $*" >&2; }
ok()   { echo "  ✓ $*"; }

# Load ~/.config/ship-feature/config as plain KEY=value lines — NEVER shell-`source`d, and only known
# SHIP_FEATURE_* keys are honored. Environment variables win over the file.
load_config() {
  local cfg="${SHIP_FEATURE_CONFIG:-$HOME/.config/ship-feature/config}" key val
  [ -f "$cfg" ] || return 0
  while IFS='=' read -r key val; do
    case "$key" in ''|\#*) continue;; esac
    key="$(printf '%s' "$key" | tr -d '[:space:]')"
    val="${val%%[[:space:]]#*}"                                                   # strip an inline "# comment"
    val="${val#"${val%%[![:space:]]*}"}"; val="${val%"${val##*[![:space:]]}"}"     # trim surrounding space
    case "$key" in
      SHIP_FEATURE_WORKTREE_ROOT) [ -n "${SHIP_FEATURE_WORKTREE_ROOT:-}" ] || SHIP_FEATURE_WORKTREE_ROOT="$val" ;;
      SHIP_FEATURE_EXCLUDE_MARKER) [ -n "${SHIP_FEATURE_EXCLUDE_MARKER:-}" ] || SHIP_FEATURE_EXCLUDE_MARKER="$val" ;;
      SHIP_FEATURE_DENYLIST) [ -n "${SHIP_FEATURE_DENYLIST:-}" ] || SHIP_FEATURE_DENYLIST="$val" ;;
      SHIP_FEATURE_REVIEWERS) [ -n "${SHIP_FEATURE_REVIEWERS:-}" ] || SHIP_FEATURE_REVIEWERS="$val" ;;
    esac
  done < "$cfg"
}

default_branch() {
  # refs/remotes/origin/HEAD -> the ref it points to, minus the "origin/" remote prefix.
  # Strip only the remote prefix (not everything up to the last /) so branch names containing '/'
  # (e.g. "release/main") survive.
  local ref
  ref=$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) || return 1
  ref="${ref#refs/remotes/origin/}"
  printf '%s\n' "$ref"
}

cmd_preflight() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git working tree."
  load_config
  local worktree_root="${SHIP_FEATURE_WORKTREE_ROOT:-.claude/worktrees}"
  worktree_root="${worktree_root%/}"   # tolerate a trailing slash (else the "/root/" match breaks)
  local exclude_marker="${SHIP_FEATURE_EXCLUDE_MARKER:-.claude/}"

  local def cur common_dir git_dir top
  def=$(default_branch) || die "cannot resolve origin/HEAD (the default branch). Run: git remote set-head origin -a"
  ok "default branch: $def"

  cur=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || die "cannot read current branch."
  [ "$cur" != "HEAD" ] || die "detached HEAD — check out a named feature branch before implementing."
  [ "$cur" != "$def" ] || die "you are on the default branch '$def' — create a feature branch/worktree first."
  ok "on feature branch: $cur"

  # Linked worktree: --git-dir and --git-common-dir are identical in the main tree and differ in a
  # linked worktree. (More robust than matching "/worktrees/" in the path, which a repo cloned under a
  # directory literally named "worktrees" would trip.)
  git_dir=$(git rev-parse --absolute-git-dir 2>/dev/null)
  common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
  # `CDPATH=` disables CDPATH lookups and the `./` prefix stops a value like `-` being read as an option.
  case "$common_dir" in /*) : ;; *) common_dir=$(CDPATH= cd "./$common_dir" 2>/dev/null && pwd) ;; esac
  if [ -n "$git_dir" ] && [ "$git_dir" != "$common_dir" ]; then
    ok "in a linked worktree"
  else
    die "not in a linked worktree — use 'git worktree add' (never work in the main tree)."
  fi

  # Worktree lives under the configured root (a workflow requirement, not just advice).
  top=$(git rev-parse --show-toplevel 2>/dev/null)
  case "$top" in
    *"/$worktree_root/"*) ok "worktree under $worktree_root/" ;;
    *) die "worktree is not under $worktree_root/ — create it there (or set SHIP_FEATURE_WORKTREE_ROOT)." ;;
  esac

  # The marker must actually be IGNORED — ask git, don't grep the exclude file (a commented or negated
  # rule would pass a grep but not real ignore behavior). check-ignore consults .gitignore + info/exclude.
  local probe="${exclude_marker%/}/.ship-feature-probe"
  if git check-ignore -q "$probe" 2>/dev/null; then
    ok "$exclude_marker is git-ignored"
  else
    die "$exclude_marker is not ignored — add it to $common_dir/info/exclude (or .gitignore)."
  fi

  # The default-branch tracking ref must be fetched to compare against it.
  git rev-parse --verify --quiet "origin/$def" >/dev/null 2>&1 || die "cannot resolve origin/$def — run 'git fetch' first."

  # Ancestry: the feature branch must actually descend from the current default branch.
  if git merge-base --is-ancestor "origin/$def" HEAD 2>/dev/null; then
    ok "branch descends from origin/$def"
  elif git merge-base "origin/$def" HEAD >/dev/null 2>&1; then
    if [ -n "${SHIP_FEATURE_ALLOW_BEHIND:-}" ]; then
      warn "branch is behind or diverged from origin/$def — allowed via SHIP_FEATURE_ALLOW_BEHIND."
    else
      die "branch is behind or diverged from origin/$def — rebase onto the default branch, or set SHIP_FEATURE_ALLOW_BEHIND=1 to proceed on a stale base."
    fi
  else
    die "no common history with origin/$def — did you branch off the default branch?"
  fi

  echo "✔ preflight passed."
}

cmd_relay() {
  command -v pr-review-relay >/dev/null 2>&1 || die "pr-review-relay not found on PATH (it is a dependency: https://github.com/hamen/pr-review-relay)."
  load_config
  # If the caller omitted --reviewers and a quorum is configured, inject it (still fully overridable by
  # passing --reviewers yourself). stdout and the exact exit code are always preserved.
  local a has_reviewers=0
  for a in "$@"; do case "$a" in --reviewers|--reviewers=*) has_reviewers=1;; esac; done
  if [ "$has_reviewers" = 0 ] && [ -n "${SHIP_FEATURE_REVIEWERS:-}" ]; then
    pr-review-relay "$@" --reviewers "$SHIP_FEATURE_REVIEWERS"
  else
    pr-review-relay "$@"
  fi
  local rc=$?
  # Workflow-policy reminder only (on stderr, so it never pollutes the forwarded stdout).
  case "$rc" in
    0) echo "  → relay: every reviewer ran (exit 0). This is NOT approval — READ the verdicts and resolve every Blocker/Should-fix before merging." >&2 ;;
    3) echo "  → relay: round not clean (exit 3) — do not trust these reviews, re-run." >&2 ;;
    4) echo "  → relay: round cap reached (exit 4) — stop and escalate to a human." >&2 ;;
  esac
  return $rc
}

main() {
  local sub="${1:-help}"
  [ $# -gt 0 ] && shift
  case "$sub" in
    preflight) cmd_preflight "$@" ;;
    relay)     cmd_relay "$@" ;;
    help|-h|--help) sed -n '2,13p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown command: $sub (try: ship-feature help)" ;;
  esac
}
main "$@"
