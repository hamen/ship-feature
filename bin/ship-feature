#!/usr/bin/env bash
# ship-feature — a small helper for the ship-feature workflow (see WORKFLOW.md).
#
# v1 commands:
#   ship-feature preflight   Assert the working copy is set up for step 4 (worktree, feature
#                            branch off origin/HEAD, excluded marker, ancestry). Non-zero on failure.
#   ship-feature relay [..]  Transparent pass-through to `pr-review-relay`: forwards all args, preserves
#                            stdout and the EXACT exit code, and prints (on stderr) a one-line reminder of
#                            what each code means for the workflow.
#   ship-feature plan-review [<file>] [--reviewers a,b,c] [--parallel]
#                            Step 2: fan an implementation PLAN (a file, stdin, or ./plan.md) out to a
#                            panel of agents for a read-only review; prints each review. Defaults the
#                            panel to SHIP_FEATURE_REVIEWERS. Exit 0 clean, 3 not-clean, 1 usage error.
#   ship-feature help        This message.
#
# The workflow itself lives in WORKFLOW.md; this tool does not drive it. State/resume is intentionally
# NOT in v1. Bash 3.2-safe (no associative arrays, no ${x^}); no jq dependency.
set -uo pipefail

die()  { echo "✖ $*" >&2; exit 1; }
warn() { echo "  ! $*" >&2; }
ok()   { echo "  ✓ $*"; }

# Load ~/.config/ship-feature/config as plain KEY=value lines — NEVER shell-`source`d, and only known
# SHIP_FEATURE_* keys are honored. Environment variables win over the file.
load_config() {
  local cfg="${SHIP_FEATURE_CONFIG:-$HOME/.config/ship-feature/config}" key val
  [ -f "$cfg" ] || return 0
  while IFS='=' read -r key val; do
    case "$key" in ''|\#*) continue;; esac
    key="$(printf '%s' "$key" | tr -d '[:space:]')"
    val="${val%%[[:space:]]#*}"                                                   # strip an inline "# comment"
    val="${val#"${val%%[![:space:]]*}"}"; val="${val%"${val##*[![:space:]]}"}"     # trim surrounding space
    case "$key" in
      # Use ${VAR+x} (is it DEFINED?) not ${VAR:-} (is it non-empty?), so an explicitly empty environment
      # value (e.g. SHIP_FEATURE_REVIEWERS=) wins over the config file and disables it.
      SHIP_FEATURE_WORKTREE_ROOT) [ -n "${SHIP_FEATURE_WORKTREE_ROOT+x}" ] || SHIP_FEATURE_WORKTREE_ROOT="$val" ;;
      SHIP_FEATURE_EXCLUDE_MARKER) [ -n "${SHIP_FEATURE_EXCLUDE_MARKER+x}" ] || SHIP_FEATURE_EXCLUDE_MARKER="$val" ;;
      SHIP_FEATURE_DENYLIST) [ -n "${SHIP_FEATURE_DENYLIST+x}" ] || SHIP_FEATURE_DENYLIST="$val" ;;
      SHIP_FEATURE_REVIEWERS) [ -n "${SHIP_FEATURE_REVIEWERS+x}" ] || SHIP_FEATURE_REVIEWERS="$val" ;;
    esac
  done < "$cfg"
}

default_branch() {
  # refs/remotes/origin/HEAD -> the ref it points to, minus the "origin/" remote prefix.
  # Strip only the remote prefix (not everything up to the last /) so branch names containing '/'
  # (e.g. "release/main") survive.
  local ref
  ref=$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) || return 1
  ref="${ref#refs/remotes/origin/}"
  printf '%s\n' "$ref"
}

cmd_preflight() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git working tree."
  load_config
  local worktree_root="${SHIP_FEATURE_WORKTREE_ROOT:-.claude/worktrees}"
  worktree_root="${worktree_root%/}"   # tolerate a trailing slash (else the "/root/" match breaks)
  # Default the excluded marker to the TOP component of the worktree root so they always correspond —
  # otherwise a custom root (e.g. ".worktrees") could pass while an unrelated ".claude/" is what's ignored.
  local exclude_marker="${SHIP_FEATURE_EXCLUDE_MARKER:-${worktree_root%%/*}/}"

  local def cur common_dir git_dir top
  def=$(default_branch) || die "cannot resolve origin/HEAD (the default branch). Run: git remote set-head origin -a"
  ok "default branch: $def"

  cur=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || die "cannot read current branch."
  [ "$cur" != "HEAD" ] || die "detached HEAD — check out a named feature branch before implementing."
  [ "$cur" != "$def" ] || die "you are on the default branch '$def' — create a feature branch/worktree first."
  ok "on feature branch: $cur"

  # Linked worktree: --git-dir and --git-common-dir are identical in the main tree and differ in a
  # linked worktree. (More robust than matching "/worktrees/" in the path, which a repo cloned under a
  # directory literally named "worktrees" would trip.)
  git_dir=$(git rev-parse --absolute-git-dir 2>/dev/null)
  common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
  # `CDPATH=` disables CDPATH lookups and the `./` prefix stops a value like `-` being read as an option.
  case "$common_dir" in /*) : ;; *) common_dir=$(CDPATH= cd "./$common_dir" 2>/dev/null && pwd) ;; esac
  if [ -n "$git_dir" ] && [ "$git_dir" != "$common_dir" ]; then
    ok "in a linked worktree"
  else
    die "not in a linked worktree — use 'git worktree add' (never work in the main tree)."
  fi

  # Worktree lives under the configured root (a workflow requirement, not just advice).
  top=$(git rev-parse --show-toplevel 2>/dev/null)
  case "$top" in
    *"/$worktree_root/"*) ok "worktree under $worktree_root/" ;;
    *) die "worktree is not under $worktree_root/ — create it there (or set SHIP_FEATURE_WORKTREE_ROOT)." ;;
  esac

  # The marker must actually be IGNORED — ask git, don't grep the exclude file (a commented or negated
  # rule would pass a grep but not real ignore behavior). check-ignore consults .gitignore + info/exclude.
  local probe="${exclude_marker%/}/.ship-feature-probe"
  if git check-ignore -q "$probe" 2>/dev/null; then
    ok "$exclude_marker is git-ignored"
  else
    die "$exclude_marker is not ignored — add it to $common_dir/info/exclude (or .gitignore)."
  fi

  # The default-branch tracking ref must be fetched to compare against it.
  git rev-parse --verify --quiet "origin/$def" >/dev/null 2>&1 || die "cannot resolve origin/$def — run 'git fetch' first."

  # Ancestry: the feature branch must actually descend from the current default branch.
  if git merge-base --is-ancestor "origin/$def" HEAD 2>/dev/null; then
    ok "branch descends from origin/$def"
  elif git merge-base "origin/$def" HEAD >/dev/null 2>&1; then
    if [ -n "${SHIP_FEATURE_ALLOW_BEHIND:-}" ]; then
      warn "branch is behind or diverged from origin/$def — allowed via SHIP_FEATURE_ALLOW_BEHIND."
    else
      die "branch is behind or diverged from origin/$def — rebase onto the default branch, or set SHIP_FEATURE_ALLOW_BEHIND=1 to proceed on a stale base."
    fi
  else
    die "no common history with origin/$def — did you branch off the default branch?"
  fi

  echo "✔ preflight passed."
}

cmd_relay() {
  command -v pr-review-relay >/dev/null 2>&1 || die "pr-review-relay not found on PATH (it is a dependency: https://github.com/hamen/pr-review-relay)."
  load_config
  # If the caller omitted --reviewers and a quorum is configured, inject it (still fully overridable by
  # passing --reviewers yourself). stdout and the exact exit code are always preserved.
  local a has_reviewers=0
  for a in "$@"; do case "$a" in
    --reviewers) has_reviewers=1 ;;
    # pr-review-relay only accepts the two-token form; reject the =form with a clear message rather than
    # passing it through and letting the relay die with "unknown arg".
    --reviewers=*) die "pass reviewers as two tokens: --reviewers <list> (the --reviewers=... form isn't supported)." ;;
  esac; done
  if [ "$has_reviewers" = 1 ]; then
    pr-review-relay "$@"
  elif [ -n "${SHIP_FEATURE_REVIEWERS:-}" ]; then
    pr-review-relay "$@" --reviewers "$SHIP_FEATURE_REVIEWERS"
  else
    echo "  note: no explicit --reviewers and SHIP_FEATURE_REVIEWERS is unset — the relay may run a thinned panel. Set your quorum for a fail-closed cross-review." >&2
    pr-review-relay "$@"
  fi
  local rc=$?
  # Workflow-policy reminder only (on stderr, so it never pollutes the forwarded stdout).
  case "$rc" in
    0) echo "  → relay: every reviewer ran (exit 0). This is NOT approval — READ the verdicts and resolve every Blocker/Should-fix before merging." >&2 ;;
    3) echo "  → relay: round not clean (exit 3) — do not trust these reviews, re-run." >&2 ;;
    4) echo "  → relay: round cap reached (exit 4) — stop and escalate to a human." >&2 ;;
  esac
  return $rc
}

# --- plan review (step 2 of the workflow) ------------------------------------
# Fan an implementation PLAN out to a panel of agents for a read-only review, BEFORE
# any code is written — the cheap gate that catches wrong assumptions and stale facts.
# Unlike `relay` (which reviews a PR via pr-review-relay and posts comments), this
# reviews a local plan file / stdin and prints each review to the terminal. Nothing
# is posted anywhere; nothing is written.
#
# Supported reviewers are ONLY those that can be run genuinely read-only over the plan
# text: claude (--permission-mode plan), codex (--sandbox read-only), cursor (--mode=ask,
# Q&A), qwen (--approval-mode plan, its read-only mode that denies edit/write/shell, plus
# --safe-mode to also block checkout config). agy and opencode are RELAY-ONLY here — agy
# has no read-only mode (its relay flag disables ALL permissions) and opencode needs the
# file-attach path — so if listed they are skipped with a warning, never run. That keeps
# the "read-only, nothing is written" guarantee true for the whole set that actually runs.
plan_tool_for() { case "$1" in
  claude) echo claude;; codex) echo codex;; cursor) echo cursor-agent;; qwen) echo qwen;; *) echo "";; esac; }
# Named but deliberately not run in plan-review (available in `relay`).
plan_relay_only() { case "$1" in opencode|antigravity|agy) return 0;; *) return 1;; esac; }

cmd_plan_review() {
  load_config
  local reviewers="" file="" parallel=0 have_file=0
  while [ $# -gt 0 ]; do
    case "$1" in
      # Guard $2 so a trailing `--reviewers` (or one followed by a flag) is a clean usage
      # error, not a `set -u` unbound-variable crash.
      --reviewers)   [ $# -ge 2 ] || die "--reviewers needs a list (e.g. --reviewers codex,qwen)."
                     case "$2" in -*) die "--reviewers needs a list, got the flag '$2'.";; esac
                     reviewers="$2"; shift 2;;
      --reviewers=*) die "pass reviewers as two tokens: --reviewers <list> (the --reviewers=... form isn't supported)." ;;
      --parallel)    parallel=1; shift;;
      -h|--help)     echo "usage: ship-feature plan-review [<plan-file>] [--reviewers a,b,c] [--parallel]"; return 0;;
      # Everything after `--` is positional — collect the plan file from there too, don't drop it.
      --)            shift; while [ $# -gt 0 ]; do [ "$have_file" = 0 ] || die "only one plan file may be given."; file="$1"; have_file=1; shift; done; break;;
      -)             [ "$have_file" = 0 ] || die "only one plan file may be given (got '$file' and '-')."; file="-"; have_file=1; shift;;   # '-' = read stdin
      -*)            die "unknown arg: $1" ;;
      *)             [ "$have_file" = 0 ] || die "only one plan file may be given (got '$file' and '$1')."; file="$1"; have_file=1; shift;;
    esac
  done

  # Resolve the plan text. Explicit `-` means "read stdin" even on a TTY (and never
  # falls back to ./plan.md). An explicit file wins next. Otherwise read stdin if it is
  # a pipe; an EMPTY pipe (common in CI / subprocesses) must NOT shadow ./plan.md, so
  # fall back to it when stdin yielded nothing.
  local plan="" src=""
  if [ "$have_file" = 1 ] && [ "$file" = "-" ]; then
    plan="$(cat)"; src="(stdin)"
    [ -n "$(printf '%s' "$plan" | tr -d '[:space:]')" ] || die "no plan on stdin (you passed '-')."
  elif [ "$have_file" = 1 ]; then
    [ -f "$file" ] || die "plan file not found: $file"
    plan="$(cat -- "$file")"; src="$file"
    [ -n "$(printf '%s' "$plan" | tr -d '[:space:]')" ] || die "plan file is empty: $file"
  else
    if [ ! -t 0 ]; then plan="$(cat)"; [ -n "$(printf '%s' "$plan" | tr -d '[:space:]')" ] && src="(stdin)"; fi
    if [ -z "$(printf '%s' "$plan" | tr -d '[:space:]')" ] && [ -f plan.md ]; then plan="$(cat plan.md)"; src="plan.md"; fi
    [ -n "$(printf '%s' "$plan" | tr -d '[:space:]')" ] || die "no plan given — pass a file, pipe it on stdin, or create a non-empty ./plan.md."
  fi

  # Panel: --reviewers > SHIP_FEATURE_REVIEWERS > refuse. The resolved panel is your
  # QUORUM: every named+supported reviewer is required (a missing CLI fails the round),
  # so a review never silently passes on a thinned panel. agy/opencode are the exception.
  [ -z "$reviewers" ] && reviewers="${SHIP_FEATURE_REVIEWERS:-}"
  [ -n "$reviewers" ] || die "no reviewers — pass --reviewers <list> or set SHIP_FEATURE_REVIEWERS (e.g. codex,qwen)."

  # Portable timeout: GNU `timeout`, else Homebrew `gtimeout`, else run WITHOUT a limit
  # (stock macOS ships neither) — a missing timeout must never break the reviewer.
  local TIMEOUT_BIN; TIMEOUT_BIN="$(command -v timeout 2>/dev/null || command -v gtimeout 2>/dev/null || true)"
  local timeout_s="${SHIP_FEATURE_PLAN_TIMEOUT:-${PR_RELAY_AGENT_TIMEOUT:-300}}"
  # Reject non-digits AND values that are numerically zero ("0", "00", …): GNU
  # `timeout 0` DISABLES the timeout, the opposite of the intent. 10# forces base-10 so
  # a leading zero isn't read as octal.
  case "$timeout_s" in ''|*[!0-9]*) die "invalid SHIP_FEATURE_PLAN_TIMEOUT: '$timeout_s' (want a positive integer)";; esac
  [ "$((10#$timeout_s))" -gt 0 ] || die "invalid SHIP_FEATURE_PLAN_TIMEOUT: '$timeout_s' (must be > 0)"

  local PROMPT
  PROMPT="$(printf '%s' \
'You are reviewing an IMPLEMENTATION PLAN (provided on stdin), BEFORE any code is written.
Judge it for: wrong assumptions, stale or incorrect facts about the codebase, missing edge
cases, unhandled failure modes, risky or out-of-order steps, and anything it overlooks.
You have read-only access — do NOT write code or modify anything. Be concise. Group findings
by severity: Blocker / Should-fix / Nit. If the plan is sound, say so in one line.')"

  echo "▶ Plan review — reviewers: $reviewers${src:+ — plan: $src}$([ "$parallel" = 1 ] && printf ' — parallel')" >&2

  # Per-reviewer state lives in files so it survives the subshells used under --parallel
  # (same technique as pr-review-relay). The trap embeds the path by value — no live
  # variable to go unbound — and kills any parallel reviewer children so an interrupt
  # doesn't leave agents running and burning credits.
  # umask 077 so the buffered plan/review temp files created below are 0600 — defence in
  # depth on a shared machine, on top of the 0700 dir mktemp gives us. Not restored: this
  # is the CLI's terminal command, the process exits right after.
  umask 077
  local STATUS_DIR; STATUS_DIR="$(mktemp -d)" || die "cannot create temp dir"
  trap "rm -rf '$STATUS_DIR'" EXIT
  trap 'p=$(jobs -p 2>/dev/null); [ -n "$p" ] && kill $p 2>/dev/null; exit 130' INT TERM
  skey() { printf 'k_%s' "$(printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_')"; }

  # Run a reviewer command under the timeout when one is available, else directly.
  run_reviewer() { if [ -n "$TIMEOUT_BIN" ]; then "$TIMEOUT_BIN" "$timeout_s" "$@"; else "$@"; fi; }

  # Both the review (stdout) and the diagnostics (stderr-bound) are buffered to files, so
  # under --parallel neither the reviews nor the failure messages interleave; the caller
  # emits them in panel order after the barrier. qwen runs `--approval-mode plan` — its
  # genuine read-only mode that denies edit/write/shell — NOT `yolo` (which auto-approves
  # those). `--safe-mode` additionally blocks any checkout config from loading.
  plan_review_with() {
    local name="$1" out rc=0 errf key Name why
    key="$(skey "$name")"; errf="$STATUS_DIR/err_$key"       # in STATUS_DIR so it can't leak
    Name="$(printf '%s' "${name:0:1}" | tr '[:lower:]' '[:upper:]')${name:1}"
    case "$name" in
      claude) out=$(printf '%s' "$plan" | run_reviewer claude -p --permission-mode plan "$PROMPT" 2>"$errf"); rc=$?;;
      codex)  out=$(printf '%s' "$plan" | run_reviewer codex exec --sandbox read-only "$PROMPT" 2>"$errf"); rc=$?;;
      cursor) out=$(printf '%s\n\n---\n%s' "$PROMPT" "$plan" | run_reviewer cursor-agent -p --mode=ask 2>"$errf"); rc=$?;;
      qwen)   out=$(printf '%s' "$plan" | run_reviewer qwen --safe-mode --approval-mode plan -p "$PROMPT" 2>"$errf"); rc=$?;;
    esac
    if [ -z "$(printf '%s' "$out" | tr -d '[:space:]')" ]; then
      why="exited with code $rc"
      case "$rc" in 0) why="ran but returned an empty review";; 124) why="timed out after ${timeout_s}s (raise SHIP_FEATURE_PLAN_TIMEOUT)";; 127) why="command not found";; esac
      { printf '  ! %s: no review — %s\n' "$name" "$why"; [ "$rc" != 124 ] && [ -s "$errf" ] && tail -n 10 "$errf" | sed 's/^/    │ /'; } > "$STATUS_DIR/diag_$key"
      echo fail > "$STATUS_DIR/$key"; return 0
    fi
    printf '\n========== %s (plan review) ==========\n%s\n=======================================\n' "$Name" "$out" > "$STATUS_DIR/out_$key"
    if [ "$rc" -ne 0 ]; then
      # Name the timeout explicitly: a bare "exited with code 124" is opaque.
      if [ "$rc" = 124 ]; then printf '  ! %s: timed out after %ss — review may be truncated (not clean)\n' "$name" "$timeout_s" > "$STATUS_DIR/diag_$key"
      else printf '  ! %s: exited with code %s — review may be truncated (not clean)\n' "$name" "$rc" > "$STATUS_DIR/diag_$key"; fi
      echo fail > "$STATUS_DIR/$key"
    else echo ok > "$STATUS_DIR/$key"; fi
  }

  # Dispatch, de-duping the panel. `set -f` guards the word-split from pathname expansion
  # (an unquoted `$reviewers` would otherwise glob a value like `a*`).
  local r rk tool seen="" order=""
  local IFS_SAVE="$IFS"; set -f; IFS=','; set -- $reviewers; IFS="$IFS_SAVE"; set +f
  for r in "$@"; do
    r="$(printf '%s' "$r" | tr -d '[:space:]')"; [ -z "$r" ] && continue
    [ "$r" = "agy" ] && r=antigravity
    rk="$(skey "$r")"
    case " $seen " in *" $rk "*) continue;; esac
    seen="$seen $rk"
    if plan_relay_only "$r"; then warn "$r is relay-only (no read-only mode / needs file-attach) — not run in plan-review; skipping."; continue; fi
    tool="$(plan_tool_for "$r")"
    # A named reviewer that is unknown, or supported-but-not-installed, is a hard failure:
    # the panel is the quorum, so a review must not quietly pass with it missing.
    if [ -z "$tool" ]; then echo fail > "$STATUS_DIR/$rk"; warn "unknown reviewer '$r' → fail"; continue; fi
    if ! command -v "$tool" >/dev/null 2>&1; then echo fail > "$STATUS_DIR/$rk"; warn "$tool not installed (required by the panel) → fail"; continue; fi
    order="$order $rk"
    echo "  → $r reviewing…" >&2
    echo pending > "$STATUS_DIR/$rk"
    if [ "$parallel" = 1 ]; then
      plan_review_with "$r" &
    else
      # Sequential: run and stream this review immediately (no interleave risk), so a
      # slow first reviewer doesn't make the whole panel silent until the end.
      plan_review_with "$r"
      [ -f "$STATUS_DIR/out_$rk" ]  && cat "$STATUS_DIR/out_$rk"
      [ -f "$STATUS_DIR/diag_$rk" ] && cat "$STATUS_DIR/diag_$rk" >&2
    fi
  done
  [ "$parallel" = 1 ] && wait

  # Parallel: reviews and diagnostics were buffered per reviewer; emit them in panel
  # order now, so neither the stdout reviews nor the stderr failures interleave.
  if [ "$parallel" = 1 ]; then
    local e; for e in $order; do
      [ -f "$STATUS_DIR/out_$e" ]  && cat "$STATUS_DIR/out_$e"
      [ -f "$STATUS_DIR/diag_$e" ] && cat "$STATUS_DIR/diag_$e" >&2
    done
  fi

  # Fail-closed verdict. Only status files (k_*) are counted — out_/err_ are excluded.
  local f ran=0 failed=0 names=""
  for f in "$STATUS_DIR"/k_*; do
    [ -e "$f" ] || continue
    ran=$((ran + 1))
    if [ "$(cat "$f")" != ok ]; then failed=$((failed + 1)); names="$names ${f##*/k_}"; fi
  done
  if [ "$ran" = 0 ]; then
    die "no supported reviewers ran. plan-review supports: claude, codex, cursor, qwen (agy/opencode are relay-only). Pass --reviewers with a supported agent."
  fi
  if [ "$failed" -gt 0 ]; then echo "✖ Plan review NOT clean: $failed/$ran reviewer(s) failed —$names. Fix and re-run." >&2; return 3; fi
  echo "✔ Plan review done — $ran/$ran reviewer(s) responded. READ the findings and revise the plan before Gate 1." >&2
  return 0
}

main() {
  local sub="${1:-help}"
  [ $# -gt 0 ] && shift
  case "$sub" in
    preflight)   cmd_preflight "$@" ;;
    relay)       cmd_relay "$@" ;;
    plan-review) cmd_plan_review "$@" ;;
    help|-h|--help) sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown command: $sub (try: ship-feature help)" ;;
  esac
}
main "$@"
